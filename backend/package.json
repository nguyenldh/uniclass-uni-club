{
  "name": "@uniclub/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed:bots": "tsx src/scripts/seed-bots.ts",
    "seed:bots:force": "tsx src/scripts/seed-bots.ts --force",
    "seed:questions": "tsx src/games/quiz-arena/scripts/seed-questions.ts",
    "seed:admin": "tsx src/scripts/seed-admin.ts"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "@uniclub/shared": "*",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "mongoose": "^8.5.0",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.0.0",
    "ioredis-mock": "^8.13.1",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.7"
  }
}
