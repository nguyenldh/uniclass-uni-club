# ─── Server ───
PORT=3000
NODE_ENV=development

# ─── MongoDB ───
MONGO_URI=mongodb://localhost:27017/uniclub

# ─── Redis ───
# Mode: "standalone" hoặc "cluster"
REDIS_MODE=standalone

# Standalone config
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Cluster config (chỉ dùng khi REDIS_MODE=cluster)
# REDIS_CLUSTER_NODES=host1:6379,host2:6380,host3:6381

# ─── JWT ───
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# ─── Kafka ───
# Enable/disable Kafka integration
KAFKA_ENABLED=false

# Kafka brokers (comma-separated)
KAFKA_BROKERS=localhost:9092

# Client ID for Kafka producer
KAFKA_CLIENT_ID=uniclub-backend

# Enable SSL for Kafka connection
KAFKA_SSL_ENABLED=false

# SASL credentials (only used when KAFKA_SSL_ENABLED=true)
# When provided, SASL/PLAIN authentication is used over SSL.
# If SSL is disabled, these credentials are ignored.
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
