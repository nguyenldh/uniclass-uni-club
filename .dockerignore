.vscode
.idea
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
logs
*.log
npm-debug.log*

# Test
coverage
**/.nyc_output

# Documentation (optional - remove if you want docs in image)
docs
*.md
!README.md

# Docker files not needed in context
docker-compose*.yml
Dockerfile*

# Development files
.eslintrc*
.prettierrc*
vitest.config.*
jest.config.*

# Temporary files
tmp
temp
*.tmp
*.temp
