# UniClub Environment Variables for Docker Compose
# Copy this file to .env and customize values
#
# SECURITY WARNING: 
# - Never commit .env file to version control
# - Use strong, unique passwords for each service
# - Generate secrets with: openssl rand -base64 32

# ===================
# MongoDB (REQUIRED)
# ===================
# Use strong password - minimum 16 characters with letters, numbers, symbols
MONGO_ROOT_USERNAME=uniclub_admin
MONGO_ROOT_PASSWORD=CHANGE_ME_use_strong_password_here

# ===================
# Redis (REQUIRED)
# ===================
# Use strong password - minimum 16 characters
REDIS_PASSWORD=CHANGE_ME_use_strong_password_here

# ===================
# JWT (REQUIRED)
# ===================
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64
JWT_EXPIRES_IN=7d

# ===================
# Frontend URLs
# ===================
# For production, change to your actual domain
VITE_API_BASE_URL=http://localhost:3000/api
VITE_SOCKET_URL=http://localhost:3000

# ===================
# CMS URLs
# ===================
VITE_CMS_API_BASE_URL=http://localhost:3000/api/admin
